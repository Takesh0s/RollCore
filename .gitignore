# ------------------------------------------------------------------------------
# RollCore — .gitignore
# Monorepo: Frontend (React + Vite + Capacitor) + Backend (Spring Boot)
# ------------------------------------------------------------------------------

# ==============================================================================
# Node.js / Frontend Dependencies
# ==============================================================================

node_modules/

# ==============================================================================
# Frontend Build Artifacts
# ==============================================================================

dist/
dist-ssr/
.vite/

# TypeScript incremental compilation
*.tsbuildinfo

# ==============================================================================
# Backend Build Artifacts (Spring Boot / Maven)
# ==============================================================================

backend/target/
target/

# Maven Wrapper (keep committed)
# DO NOT ignore:
# .mvn/
# mvnw
# mvnw.cmd

# ==============================================================================
# Environment Variables / Local Config
# ==============================================================================

.env
.env.local
.env.*.local
*.local

# ==============================================================================
# Vercel
# ==============================================================================

.vercel/

# ==============================================================================
# Capacitor — Android
# ==============================================================================

android/build/
android/app/build/
android/.gradle/
android/local.properties

# ==============================================================================
# Capacitor — iOS
# ==============================================================================

ios/App/build/
ios/Pods/
ios/.symlinks/

# ==============================================================================
# IDEs / Editors
# ==============================================================================

.vscode/
.idea/

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================================================================
# Operating System Files
# ==============================================================================

.DS_Store
Thumbs.db

# ==============================================================================
# Temporary / Internal Work Files
# ==============================================================================

texto.txt
commits.sh